# ============================================
# CYBERGUARD V2.0 - ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in your keys
# NEVER commit .env.local to git!
# ============================================

# --- SUPABASE (Database + Auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OPENAI (AI Threat Analysis) ---
OPENAI_API_KEY=sk-proj-your-key-here

# --- RAZORPAY (Indian Payments) ---
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_secret_key

# --- RESEND (Transactional Emails) ---
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=alerts@cyberguard.in

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL=https://cyberguard.in
NEXT_PUBLIC_RAZORPAY_KEY=rzp_test_your_key

# --- OPTIONAL: STRIPE (Global Payments) ---
# STRIPE_SECRET_KEY=sk_test_your_key
# STRIPE_WEBHOOK_SECRET=whsec_your_secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
